# --- Arquivos locais de ferramentas / assistentes -------------------------
.assistant/
*.local.md
.mcp.json

# --- Arquivos sensíveis / segredos ----------------------------------------
.env
.env.*
*.key
*.pem
*.p12
credentials*
secrets*
*.local

# --- Python ---------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.python-version
.ipynb_checkpoints/

# --- Editores / IDEs ------------------------------------------------------
.vscode/
.idea/
*.swp

# --- Sistema operacional --------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
